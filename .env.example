# DataVault Configuration
# Copy this file to .env and fill in required values.

# Directory for Parquet cache files and manifest
VAULT_DIR=data_vault/

# Days before cached data is considered stale
VAULT_TTL_DAYS=7

# Default number of years of history to fetch from providers
VAULT_FETCH_YEARS=5

# Interactive Brokers TWS/Gateway connection
IB_HOST=127.0.0.1
IB_PORT=7497
IB_HISTORY_WAIT_SECONDS=15

# Alpha Vantage API key (REQUIRED — no default)
ALPHA_VANTAGE_API_KEY=

# If false, skip all interactive prompts (IB failure auto-fallback)
VAULT_INTERACTIVE=true

# yfinance rate limiting (rolling windows)
YF_LIMIT_PER_MIN=100
YF_LIMIT_PER_HOUR=2000
YF_LIMIT_PER_DAY=48000
